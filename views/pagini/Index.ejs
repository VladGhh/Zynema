<section id="zona-3" class="grid-item">
    <h2>Regizorii despre care discutăm astăzi</h2>
    <div id="galerie-statica">
        <% 
      
        let vectorZile = ["duminica", "luni", "marti", "miercuri", "joi", "vineri", "sambata"];
        
        let indexZiCurenta = new Date().getDay(); 

        for (let imag of locals.imagini) { 
            let afiseazaPoza = false;
            
            if (imag.intervale_zile) {
                for (let interval of imag.intervale_zile) {
                    let indexStart = vectorZile.indexOf(interval[0]); 
                    let indexStop = vectorZile.indexOf(interval[1]);  
                    
                    if (indexStart <= indexStop) {
                        // Interval normal (ex: luni - joi)
                        if (indexZiCurenta >= indexStart && indexZiCurenta <= indexStop) {
                            afiseazaPoza = true;
                            break;
                        }
                    } else {
                        // Interval peste weekend (ex: vineri - marti)
                        if (indexZiCurenta >= indexStart || indexZiCurenta <= indexStop) {
                            afiseazaPoza = true;
                            break;
                        }
                    }
                }
            } else {
                afiseazaPoza = true;
            }
                                           
            if(afiseazaPoza){
        %>
                <figure title="<%= imag.descriere_poza %>">
                    <picture> 
                        <source srcset="<%= imag.fisier_mic %>" media="(max-width: 300px)">
                        <source srcset="<%= imag.fisier_mediu %>" media="(max-width: 1200px)">
                        <img src="<%= imag.fisier %>" alt="<%= imag.continut_alternativ || imag.nume_poza %>">
                    </picture> 
                    
                    <figcaption>
                        <span class="index"></span> 
                        <strong><%= imag.nume_poza %></strong> <br>
                        <small><%= imag.descriere_poza %></small>
                    </figcaption>
                </figure>
        <% 
            } 
        } 
        %>
    </div>
</section>

